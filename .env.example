# =========================================================================
# SERVER-ONLY  (these stay on your computer / your server, never sent to a browser)
# =========================================================================

# The Lumen Wallet API base URL (staging APIM gateway).
LUMEN_API_BASE_URL=https://lumen-apim-stg.azure-api.net/wallet

# Your Lumen organization API key.
# Get this from your Lumen dashboard > API Keys.
# Paste the value without quotes, e.g.   LUMEN_API_KEY=abc-123-xyz
LUMEN_API_KEY=paste-your-api-key-here

# Your Lumen organization API secret. Same place as the key.
LUMEN_API_SECRET=paste-your-api-secret-here

# Port the local backend listens on. Change only if 8787 is already used.
SERVER_PORT=8787

# Where the local frontend lives. If you change the frontend port below,
# you must change this too (must match exactly, including the http:// part).
ALLOWED_ORIGIN=http://localhost:5173


# =========================================================================
# FRONTEND  (VITE_* values are visible in the browser - safe values only!)
# =========================================================================

# URL the React app uses to talk to the local backend.
VITE_BFF_URL=http://localhost:8787
